<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <Button
            android:id="@+id/btn_monthly_sales"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/monthly_report"
            android:layout_marginBottom="12dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        <Button
            android:id="@+id/btn_yearly_sales"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/yearly_report"
            android:layout_marginBottom="12dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        <Button
            android:id="@+id/btn_product_quantities"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Product-wise Quantities"
            android:layout_marginBottom="12dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        <Button
            android:id="@+id/btn_sales_comparison"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sales_comparison"
            android:layout_marginBottom="12dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        <Button
            android:id="@+id/btn_receivables"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/receivables"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
    </LinearLayout>
</ScrollView>
